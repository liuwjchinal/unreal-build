{
  "App": {
    "ServerUrl": "http://0.0.0.0:5080",
    "StorageRoot": "AppData",
    "GlobalConcurrency": 2,
    "UatConcurrency": 1,
    "AutomationToolCleanupEnabled": true,
    "AutomationToolCleanupMode": "TrackedOnly",
    "DefaultLogTailLines": 2000,
    "MaxLiveLogLines": 4000,
    "EventChannelCapacity": 256,
    "EventHeartbeatSeconds": 15,
    "LogEventBatchSize": 25,
    "LogEventFlushMilliseconds": 250,
    "BuildRetentionDays": 14,
    "CleanupIntervalMinutes": 60,
    "KeepRecentSuccessfulBuildsPerProject": 30,
    "MaxBuildCacheSizeGb": 20,
    "CleanupArchiveDirectories": false,
    "ScheduleServiceEnabled": true,
    "ScheduleScanIntervalSeconds": 30,
    "UbaRemoteAgentEnabled": true,
    "UbaRemoteHost": "0.0.0.0",
    "UbaPublicHost": "",
    "UbaPort": 1345,
    "UbaPortPoolSize": 16,
    "UbaAgentMaxIdleSeconds": 120,
    "UbaAgentStoreCapacityGb": 40,
    "UbaMaxWorkers": 4,
    "UbaAgentPackageSourcePath": "",
    "FrontendDevOrigin": "http://localhost:5173"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
